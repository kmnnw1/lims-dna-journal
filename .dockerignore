# Игнорируем зависимости, артефакты сборки и нерабочие файлы из образа Docker

# Каталоги и зависимости
node_modules/
.next/
.vscode/
.idea/
local/
backups/

# Git и служебные файлы репозитория
.git/
.gitignore

# Логи Node.js
npm-debug.log*

# Конфиденциальные и локальные переменные окружения
.env
.env.*
!.env.example

# Данные и приватные таблицы
*.xlsx

# Документация и markdown-файлы (исключая основные описания)
README.md
*.md

# Пояснение:
#   - !.env.example: оставляем пример env для сборки/ознакомления
#   - *.md: исключаем документацию и лишние тех.файлы, если не нужны в контейнере
#   - Можно добавить другие исключения при необходимости
