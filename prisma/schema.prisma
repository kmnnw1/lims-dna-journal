generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      String   @default("EDITOR")
  firstName String?
  lastName  String?
  createdAt DateTime @default(now())
  specimens Specimen[] @relation("LabTechnician")
  auditLogs AuditLog[] @relation("UserAuditLogs")
}

model Specimen {
  id               String       @id @default(uuid())
  taxon            String?
  locality         String?
  collector        String?
  collectedAt      DateTime?
  collectNotes     String?
  extrLab          String?
  extrOperator     String?
  extrMethod       String?
  extrDateRaw      String?
  extrDate         DateTime?
  dnaMeter         String?
  measDate         DateTime?
  measOperator     String?
  dnaConcentration Float?
  dnaProfile       String?
  measComm         String?
  imageUrl         String?
  itsStatus        String?
  itsGb            String?
  ssuStatus        String?
  ssuGb            String?
  lsuStatus        String?
  lsuGb            String?
  mcm7Status       String?
  mcm7Gb           String?
  rpb2Status       String?
  rpb2Gb           String?
  mtLsuStatus      String?
  mtLsuGb          String?
  mtSsuStatus      String?
  mtSsuGb          String?
  herbarium        String?
  accessionNumber  String?
  collectionNumber String?
  connections      String?
  labNo            String?
  notes            String?
  importOrigin     String?
  importRow        Int?
  importNotes      String?      
  reviewNotes      String?
  reviewPhotos     String?      
  attempts         PcrAttempt[]
  deletedAt        DateTime?    
  labTechnicianId  String?
  labTechnician    User?        @relation("LabTechnician", fields: [labTechnicianId], references: [id])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([deletedAt])
}

model PcrAttempt {
  id               String            @id @default(uuid())
  specimenId       String
  date             DateTime          @default(now())
  marker           String?
  forwardPrimer    String?
  reversePrimer    String?
  dnaMatrix        String?
  volume           String?
  polymerase       String?
  cycler           String?
  cycles           String?
  annealingTemp    String?
  extensionTime    String?
  result           String
  resultNotes      String?
  specimen         Specimen          @relation(fields: [specimenId], references: [id], onDelete: Cascade)
  deletedAt        DateTime?    
  createdAt        DateTime          @default(now())

  @@index([specimenId])
  @@index([marker])
  @@index([deletedAt])
}

model AuditLog {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation("UserAuditLogs", fields: [userId], references: [id])
  action        String    // CREATE_SPECIMEN, UPDATE_SPECIMEN, etc.
  resourceType  String    // SPECIMEN, PCR_ATTEMPT, etc.
  resourceId    String?   // ID of the affected resource
  details       String?   // JSON string with action details
  changes       String?   // JSON string with before/after values
  ipAddress     String?   // IP address of the request
  userAgent     String?   // User agent string
  timestamp     DateTime  @default(now())

  @@index([userId])
  @@index([timestamp])
  @@index([resourceType, resourceId])
}

model AuthToken {
  id        String   @id @default(uuid())
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
