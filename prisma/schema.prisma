generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      String   @default("EDITOR")
  createdAt DateTime @default(now())
}

model Specimen {
  id               String       @id @default(uuid())
  taxon            String?
  locality         String?
  collector        String?
  collectedAt      DateTime?
  collectNotes     String?
  extrLab          String?
  extrOperator     String?
  extrMethod       String?
  extrDateRaw      String?
  extrDate         DateTime?
  dnaMeter         String?
  measDate         DateTime?
  measOperator     String?
  dnaConcentration String?
  dnaProfile       String?
  measComm         String?
  imageUrl         String?
  itsStatus        String?
  itsGb            String?
  ssuStatus        String?
  ssuGb            String?
  lsuStatus        String?
  lsuGb            String?
  mcm7Status       String?
  mcm7Gb           String?
  rpb2Status       String?
  rpb2Gb           String?
  mtLsuStatus      String?
  mtLsuGb          String?
  mtSsuStatus      String?
  mtSsuGb          String?
  herbarium        String?
  labNo            String?
  notes            String?
  importOrigin     String?
  importRow        Int?
  importNotes      String?      
  attempts         PcrAttempt[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model PcrAttempt {
  id               String            @id @default(uuid())
  specimenId       String
  date             DateTime          @default(now())
  marker           String?
  forwardPrimer    String?
  reversePrimer    String?
  dnaMatrix        String?
  volume           String?
  polymerase       String?
  cycler           String?
  cycles           String?
  annealingTemp    String?
  extensionTime    String?
  result           String
  resultNotes      String?
  specimen         Specimen          @relation(fields: [specimenId], references: [id], onDelete: Cascade)
  sequencingResult SequencingResult?
  createdAt        DateTime          @default(now())

  @@unique([specimenId, marker])
}

model SequencingResult {
  id           String     @id @default(uuid())
  pcrAttemptId String     @unique
  pcrAttempt   PcrAttempt @relation(fields: [pcrAttemptId], references: [id], onDelete: Cascade)
  sequenceData String?    
  chromatogram String?    
  qualityScore String?    
  createdAt    DateTime   @default(now())
}

model AuditLog {
  id            String    @id @default(uuid())
  userId        String
  action        String    // CREATE_SPECIMEN, UPDATE_SPECIMEN, etc.
  resourceType  String    // SPECIMEN, PCR_ATTEMPT, etc.
  resourceId    String?   // ID of the affected resource
  details       String?   // JSON string with action details
  changes       String?   // JSON string with before/after values
  ipAddress     String?   // IP address of the request
  userAgent     String?   // User agent string
  timestamp     DateTime  @default(now())

  @@index([userId])
  @@index([timestamp])
  @@index([resourceType, resourceId])
}

model AuthToken {
  id        String   @id @default(uuid())
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}
