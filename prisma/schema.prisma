generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id         String        @id @default(uuid())
  username   String        @unique
  password   String
  role       String        @default("EDITOR")
  createdAt  DateTime      @default(now())
  firstName  String?
  lastName   String?
  lastSeenAt DateTime?
  auditLogs  AuditLog[]    @relation("UserAuditLogs")
  specimens  Specimen[]    @relation("LabTechnician")
  activities UserActivity?
}

model Technician {
  id        String     @id @default(uuid())
  name      String     @unique
  aliases   String?
  createdAt DateTime   @default(now())
  specimens Specimen[] @relation("SpecimenTechnicians")
}

model UserActivity {
  id           String   @id @default(uuid())
  userId       String   @unique
  resourceType String?
  resourceId   String?
  lastUpdate   DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])

  @@index([resourceType, resourceId])
}

model Specimen {
  id               String       @id @default(uuid())
  taxon            String?
  locality         String?
  collector        String?
  collectedAt      DateTime?
  collectNotes     String?
  extrLab          String?
  extrOperator     String?
  extrMethod       String?
  extrDateRaw      String?
  extrDate         DateTime?
  dnaMeter         String?
  measDate         DateTime?
  measOperator     String?
  dnaConcentration Float?
  dnaProfile       String?
  measComm         String?
  imageUrl         String?
  itsStatus        String?
  itsGb            String?
  ssuStatus        String?
  ssuGb            String?
  lsuStatus        String?
  lsuGb            String?
  mcm7Status       String?
  mcm7Gb           String?
  rpb2Status       String?
  rpb2Gb           String?
  mtLsuStatus      String?
  mtLsuGb          String?
  mtSsuStatus      String?
  mtSsuGb          String?
  herbarium        String?
  labNo            String?
  notes            String?
  importOrigin     String?
  importRow        Int?
  importNotes      String?
  reviewNotes      String?
  reviewPhotos     String?
  deletedAt        DateTime?
  labTechnicianId  String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  accessionNumber  String?
  collectionNumber String?
  connections      String?
  addedBy          String?
  attempts         PCRAttempt[]
  labTechnician    User?        @relation("LabTechnician", fields: [labTechnicianId], references: [id])
  technicians      Technician[] @relation("SpecimenTechnicians")

  @@index([deletedAt])
}

model PCRAttempt {
  id            String    @id @default(uuid())
  specimenId    String
  date          DateTime  @default(now())
  marker        String?
  forwardPrimer String?
  reversePrimer String?
  dnaMatrix     String?
  volume        String?
  polymerase    String?
  cycler        String?
  cycles        String?
  annealingTemp String?
  extensionTime String?
  result        String
  resultNotes   String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  addedBy       String?
  specimen      Specimen  @relation(fields: [specimenId], references: [id], onDelete: Cascade)

  @@index([specimenId])
  @@index([marker])
  @@index([deletedAt])
}

model AuditLog {
  id           String   @id @default(uuid())
  userId       String
  action       String
  resourceType String
  resourceId   String?
  details      String?
  changes      String?
  ipAddress    String?
  userAgent    String?
  timestamp    DateTime @default(now())
  user         User     @relation("UserAuditLogs", fields: [userId], references: [id])

  @@index([userId])
  @@index([timestamp])
  @@index([resourceType, resourceId])
}

model AuthToken {
  id        String   @id @default(uuid())
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
