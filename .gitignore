# Общие файлы и каталоги для игнорирования.
# Больше примеров: https://github.com/github/gitignore/blob/main/Node.gitignore

############
# Node.js и зависимости
############
node_modules/
.pnp/
.pnp.*
.yarn/
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

############
# Кэширование и тесты
############
coverage/
.nyc_output/
*.lcov

############
# Сборка и билд-артефакты
############
.next/
out/
build/
dist/

############
# Сторонние сервисы и деплой
############
.vercel/
.backups/
.local/
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

############
# Логи и отладочная информация
############
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

############
# Окружение
############
.env*
!.env.example

############
# ОС/Системные файлы
############
.DS_Store
Thumbs.db

############
# Сертификаты, ключи, приватные файлы
############
*.pem
*.key
*.crt

############
# Таблицы и экспорт данных
############
*.xlsx
*.csv

############
# TypeScript служебные
############
*.tsbuildinfo
next-env.d.ts

############
# Prisma и база данных
############
/app/generated/prisma/
prisma/dev.db
prisma/dev.db-journal
prisma/migrations/

############
# Docker Compose: volume с данными пользователя
############
/lab-data/

############
# Локальные артефакты
############
/local/*

############
# Агентные файлы и Repomix
############
/AGENTS.md
/CLAUDE.md
repomix-output.xml
repomix-output.txt
