{
	"name": "lab-journal",
	"version": "0.21.0.63",
	"description": "Система управления лабораторной информацией (LIMS) для учёта генетического материала и протоколирования ПЦР-исследований.",
	"private": true,
	"scripts": {
		"dev": "concurrently \"next dev -H 0.0.0.0 --turbo\" \"powershell scripts/meta-sync.ps1\" \"powershell scripts/silent-ci.ps1\"",
		"dev:https": "next dev --experimental-https",
		"icons": "npx tsx scripts/gen-pwa-icons.ts",
		"prebuild": "npx tsx scripts/gen-pwa-icons.ts",
		"build": "cross-env NEXT_TURBOPACK=0 next build",
		"start": "node .next/standalone/server.js",
		"lint": "biome check .",
		"format": "biome format --write .",
		"check": "npx tsc --noEmit",
		"bump": "npx tsx scripts/bump-version.ts",
		"postinstall": "npx playwright install --with-deps",
		"prepare": "husky",
		"test": "npx prisma db push --accept-data-loss && vitest run",
		"test:ui": "vitest --ui",
		"backup": "npx tsx scripts/backup-db.ts",
		"restore": "npx tsx scripts/restore-db.ts",
		"logs:collect": "npx tsx scripts/collect-logs.ts",
		"ota:check": "npx tsx scripts/ota-check.ts",
		"setup": "npx tsx scripts/setup.ts",
		"prisma:studio": "prisma studio",
		"prisma:migrate": "prisma migrate dev",
		"prisma:generate": "prisma generate",
		"install:all": "npx tsx scripts/install-all.mjs",
		"auth": "npx tsx scripts/auth-cli.ts",
		"qa:copy": "powershell scripts/error-digest.ps1",
		"check:watch": "npx tsc --noEmit --watch"
	},
	"dependencies": {
		"@ducanh2912/next-pwa": "^10.2.9",
		"@google/generative-ai": "^0.24.1",
		"@libsql/client": "^0.17.3",
		"@prisma/adapter-better-sqlite3": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@tailwindcss/postcss": "^4.0.0",
		"@tanstack/react-query": "^5.99.0",
		"@tanstack/react-query-persist-client": "^5.99.2",
		"bcryptjs": "^3.0.3",
		"better-sqlite3": "^12.9.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.2",
		"exceljs": "^4.4.0",
		"framer-motion": "^12.38.0",
		"idb-keyval": "^6.2.2",
		"lightningcss": "^1.32.0",
		"lucide-react": "^1.8.0",
		"next": "16.2.4",
		"next-auth": "^4.24.14",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.0.0",
		"uuid": "^14.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@playwright/test": "^1.59.1",
		"@prisma/config": "^7.6.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/bcryptjs": "^2.4.6",
		"@types/better-sqlite3": "^7.6.11",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.5",
		"@types/react-dom": "^19.1.5",
		"@types/uuid": "^10.0.0",
		"concurrently": "^9.2.1",
		"cross-env": "^10.1.0",
		"drizzle-kit": "^0.31.10",
		"husky": "^9.1.7",
		"jsdom": "^29.0.2",
		"postcss": "^8.5.10",
		"prisma": "^7.8.0",
		"sharp": "^0.34.5",
		"tsx": "^4.19.2",
		"typescript": "^6.0.3",
		"vitest": "^4.1.4"
	},
	"overrides": {
		"esbuild": "0.28.0",
		"@hono/node-server": "1.19.13",
		"glob": "13.0.6",
		"rimraf": "6.1.3",
		"unzipper": "0.12.3",
		"fast-csv": "5.0.5",
		"prebuild-install": "github:prebuild/prebuild-install#v7.1.3",
		"serialize-javascript": "^6.0.2",
		"uuid": "^14.0.0",
		"terser": "^5.37.0",
		"sourcemap-codec": "npm:@jridgewell/sourcemap-codec@^1.4.15",
		"@rollup/plugin-terser": "^1.0.0",
		"source-map": "0.7.6",
		"workbox-build": "7.4.0",
		"workbox-webpack-plugin": "7.4.0",
		"@esbuild-kit/esm-loader": "npm:tsx@^4.19.2",
		"@esbuild-kit/core-utils": "npm:tsx@^4.19.2"
	},
	"engines": {
		"node": ">=24.0.0",
		"npm": ">=10.0.0"
	}
}
