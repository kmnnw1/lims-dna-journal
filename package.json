{
	"name": "lab-journal",
	"version": "0.1.23.3",
	"description": "Система управления лабораторной информацией (LIMS) для учёта генетического материала и протоколирования ПЦР-исследований.",
	"private": true,
	"scripts": {
		"dev": "next dev --turbo",
		"icons": "npx tsx scripts/gen-pwa-icons.ts",
		"prebuild": "npx tsx scripts/gen-pwa-icons.ts",
		"build": "cross-env NEXT_TURBOPACK=0 next build",
		"start": "next start",
		"lint": "eslint --ext .js,.ts,.jsx,.tsx .",
		"format": "prettier --write .",
		"bump": "npx tsx scripts/bump-version.ts",
		"prepare": "husky",
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"backup": "npx tsx scripts/backup-db.ts",
		"restore": "npx tsx scripts/restore-db.ts",
		"logs:collect": "npx tsx scripts/collect-logs.ts",
		"ota:check": "npx tsx scripts/ota-check.ts",
		"setup": "npx tsx scripts/setup.ts",
		"prisma:studio": "prisma studio",
		"prisma:migrate": "prisma migrate dev",
		"prisma:generate": "prisma generate",
		"install:all": "npx tsx scripts/install-all.ts",
		"auth": "npx tsx scripts/auth-cli.ts"
	},
	"dependencies": {
		"@google/generative-ai": "^0.24.1",
		"@prisma/adapter-better-sqlite3": "^7.7.0",
		"@prisma/client": "^7.7.0",
		"@tailwindcss/postcss": "^4.0.0",
		"better-sqlite3": "^11.8.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"exceljs": "^4.4.0",
		"lightningcss": "^1.32.0",
		"lightningcss-win32-x64-msvc": "^1.32.0",
		"lottie-react": "^2.4.1",
		"lucide-react": "^1.8.0",
		"next": "16.2.4",
		"next-auth": "^4.24.14",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.0.0"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@prisma/config": "^7.6.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/bcryptjs": "^2.4.6",
		"@types/better-sqlite3": "^7.6.11",
		"@types/node": "^20.11.30",
		"@types/react": "^19.2.5",
		"@types/react-dom": "^19.1.5",
		"cross-env": "^7.0.3",
		"eslint": "^9.2.0",
		"eslint-config-next": "16.2.4",
		"husky": "^9.1.7",
		"jsdom": "^29.0.2",
		"postcss": "^8.5.10",
		"prettier": "^3.8.3",
		"prisma": "^7.7.0",
		"sharp": "^0.34.5",
		"typescript": "^6.0.2",
		"vitest": "^4.1.4"
	},
	"engines": {
		"node": ">=18.18.0",
		"npm": ">=9.6.0"
	}
}
