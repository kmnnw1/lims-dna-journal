{
	"name": "lab-journal",
	"version": "0.1.18.0",
	"description": "Система управления лабораторной информацией (LIMS) для учёта генетического материала и протоколирования ПЦР-исследований.",
	"private": true,
	"scripts": {
		"dev": "next dev --turbo",
		"icons": "node scripts/gen-pwa-icons.mjs",
		"prebuild": "node scripts/gen-pwa-icons.mjs",
		"build": "cross-env NEXT_TURBOPACK=0 next build",
		"start": "next start",
		"lint": "eslint --ext .js,.ts,.jsx,.tsx .",
		"format": "prettier --write .",
		"bump": "node scripts/bump-version.mjs",
		"prepare": "husky",
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"backup": "node scripts/backup-db.mjs",
		"restore": "node scripts/restore-db.mjs",
		"logs:collect": "node scripts/collect-logs.mjs",
		"ota:check": "node scripts/ota-check.mjs",
		"setup": "node scripts/setup.mjs",
		"prisma:studio": "prisma studio",
		"prisma:migrate": "prisma migrate dev",
		"prisma:generate": "prisma generate",
		"install:all": "node scripts/install-all.mjs",
		"auth": "node scripts/auth-cli.mjs"
	},
	"dependencies": {
		"@google/generative-ai": "^0.24.1",
		"@prisma/client": "^5.22.0",
		"@tailwindcss/postcss": "^4.0.0",
		"bcryptjs": "^3.0.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"exceljs": "^4.4.0",
		"lightningcss": "^1.32.0",
		"lightningcss-win32-x64-msvc": "^1.32.0",
		"lottie-react": "^2.4.1",
		"lucide-react": "^0.577.0",
		"next": "16.2.1",
		"next-auth": "^4.24.13",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.0.0"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@prisma/config": "^7.6.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/bcryptjs": "^2.4.6",
		"@types/better-sqlite3": "^7.6.11",
		"@types/node": "^20.11.30",
		"@types/react": "^19.2.4",
		"@types/react-dom": "^19.1.2",
		"cross-env": "^7.0.3",
		"eslint": "^9.2.0",
		"eslint-config-next": "16.2.1",
		"husky": "^9.1.7",
		"jsdom": "^29.0.2",
		"postcss": "^8.5.8",
		"prettier": "^3.2.5",
		"prisma": "^5.22.0",
		"sharp": "^0.34.5",
		"typescript": "^5.4.5",
		"vitest": "^3.2.4"
	},
	"engines": {
		"node": ">=18.18.0",
		"npm": ">=9.6.0"
	}
}
