{
	"name": "lab-journal",
	"version": "0.3.1",
	"description": "Современный журнал учёта ДНК-проб и ПЦР-результатов для лабораторий. Next.js, Prisma, NextAuth, React, импорт/экспорт Excel.",
	"private": true,
	"scripts": {
		"dev": "next dev --turbo",
		"icons": "node scripts/gen-pwa-icons.mjs",
		"prebuild": "node scripts/gen-pwa-icons.mjs",
		"build": "cross-env NEXT_TURBOPACK=0 next build",
		"start": "next start",
		"lint": "eslint --ext .js,.ts,.jsx,.tsx .",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"backup": "node scripts/backup-db.mjs",
		"restore": "node scripts/restore-db.mjs",
		"setup": "node scripts/setup.mjs",
		"prisma:studio": "prisma studio",
		"prisma:migrate": "prisma migrate dev",
		"prisma:generate": "prisma generate",
		"install:all": "node scripts/install-all.mjs"
	},
	"dependencies": {
		"@prisma/client": "^7.6.0",
		"@tailwindcss/postcss": "^4.0.0",
		"bcryptjs": "^3.0.3",
		"exceljs": "^4.4.0",
		"lightningcss": "^1.32.0",
		"lightningcss-win32-x64-msvc": "^1.32.0",
		"lucide-react": "^0.577.0",
		"next": "16.2.1",
		"next-auth": "^4.24.13",
		"prisma": "^7.6.0",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"tailwindcss": "^4.0.0"
	},
	"devDependencies": {
		"@types/bcryptjs": "^2.4.6",
		"@types/node": "^20.11.30",
		"@types/react": "^19.2.4",
		"@types/react-dom": "^19.1.2",
		"cross-env": "^7.0.3",
		"eslint": "^9.2.0",
		"eslint-config-next": "16.2.1",
		"postcss": "^8.5.8",
		"prettier": "^3.2.5",
		"sharp": "^0.34.5",
		"typescript": "^5.4.5",
		"vitest": "^3.2.4"
	},
	"engines": {
		"node": ">=18.18.0",
		"npm": ">=9.6.0"
	}
}
