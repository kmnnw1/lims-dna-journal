{
	"name": "lab-journal",
	"version": "0.1.28.0",
	"description": "Система управления лабораторной информацией (LIMS) для учёта генетического материала и протоколирования ПЦР-исследований.",
	"private": true,
	"scripts": {
		"dev": "next dev --turbo",
		"icons": "npx tsx scripts/gen-pwa-icons.ts",
		"prebuild": "npx tsx scripts/gen-pwa-icons.ts",
		"build": "cross-env NEXT_TURBOPACK=0 next build",
		"start": "next start",
		"lint": "biome check .",
		"format": "biome format --write .",
		"check": "npx tsc --noEmit",
		"bump": "npx tsx scripts/bump-version.ts",
		"prepare": "husky",
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"backup": "npx tsx scripts/backup-db.ts",
		"restore": "npx tsx scripts/restore-db.ts",
		"logs:collect": "npx tsx scripts/collect-logs.ts",
		"ota:check": "npx tsx scripts/ota-check.ts",
		"setup": "npx tsx scripts/setup.ts",
		"prisma:studio": "prisma studio",
		"prisma:migrate": "prisma migrate dev",
		"prisma:generate": "prisma generate",
		"install:all": "npx tsx scripts/install-all.ts",
		"auth": "npx tsx scripts/auth-cli.ts",
		"check:watch": "npx tsc --noEmit --watch"
	},
	"dependencies": {
		"@google/generative-ai": "^0.24.1",
		"@libsql/client": "^0.17.2",
		"@prisma/adapter-better-sqlite3": "^7.7.0",
		"@prisma/client": "^7.7.0",
		"@tailwindcss/postcss": "^4.0.0",
		"@tanstack/react-query": "^5.99.0",
		"bcryptjs": "^3.0.3",
		"better-sqlite3": "^12.9.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.2",
		"exceljs": "^4.4.0",
		"framer-motion": "^12.38.0",
		"lightningcss": "^1.32.0",
		"lottie-react": "^2.4.1",
		"lucide-react": "^1.8.0",
		"next": "16.2.4",
		"next-auth": "^4.24.14",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.0.0",
		"uuid": "^13.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@playwright/test": "^1.59.1",
		"@prisma/config": "^7.6.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/bcryptjs": "^2.4.6",
		"@types/better-sqlite3": "^7.6.11",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.5",
		"@types/react-dom": "^19.1.5",
		"@types/uuid": "^10.0.0",
		"cross-env": "^10.1.0",
		"drizzle-kit": "^0.31.10",
		"husky": "^9.1.7",
		"jsdom": "^29.0.2",
		"postcss": "^8.5.10",
		"prisma": "^7.7.0",
		"sharp": "^0.34.5",
		"typescript": "^6.0.3",
		"vitest": "^4.1.4"
	},
	"engines": {
		"node": ">=22.0.0",
		"npm": ">=9.6.0"
	}
}
