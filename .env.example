# ⚠️ Этот файл — пример. Скопируйте его как .env и подставьте СВОИ значения.
# Не добавляйте настоящие .env в репозиторий — он должен быть в .gitignore!

# ---- БАЗА ДАННЫХ ----
# SQLite: путь относительно каталога prisma/ (см. prisma/schema.prisma)
DATABASE_URL="file:./dev.db"

# ---- АВТОРИЗАЦИЯ ----
# Критически важно: уникальная секретная строка для подписей токенов (генерируйте командой: openssl rand -base64 32)
NEXTAUTH_SECRET=

# URL приложения для обратных ссылок OAuth/почты (указывать актуальный адрес, например для продакшена!)
NEXTAUTH_URL="http://localhost:3000"

# ---- ДАННЫЕ ДЛЯ ИМПОРТА ----
# Необязательный путь к xlsx-файлу импорта. По умолчанию: /data/data.xlsx внутри контейнера Docker или ./data/data.xlsx для дев-сборки.
# DATA_XLSX_PATH=./data/data.xlsx

# ---- AI ПАРСИНГ ----
# API ключ для Google Gemini (для интеллектуального парсинга Excel)
# GEMINI_API_KEY=your_gemini_api_key_here

# ---- ДРУГИЕ ПЕРЕМЕННЫЕ (ДОБАВЛЯЙТЕ ПРИ НЕОБХОДИМОСТИ) ----

