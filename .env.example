# Скопируйте в .env и подставьте значения.
# Файл .env в репозиторий не коммитится.

# SQLite: путь относительно каталога prisma/ (см. prisma/schema.prisma)
DATABASE_URL="file:./dev.db"

NEXTAUTH_SECRET=
NEXTAUTH_URL="http://localhost:3000"

# Необязательно: путь к файлу импорта (по умолчанию data.xlsx в корне проекта)
# DATA_XLSX_PATH=data.xlsx
